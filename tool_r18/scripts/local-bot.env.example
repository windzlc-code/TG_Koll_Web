# Copy this file to:
#   .runtime/local-bot.env
#
# Put the token for the local/test Telegram bot here.
# Do not use the cloud bot token here if the cloud bot is still running.
TELEGRAM_BOT_TOKEN=

# Keep the local bot independent from the cloud instance.
TELEGRAM_INSTANCE_TAG=Tool_R18_LOCAL
TELEGRAM_WEBHOOK_PORT=18789
TELEGRAM_PROXY_URL=direct

# Local bot should normally call the local webapp backend so uploaded
# Telegram images/videos are readable by the backend on this Windows machine.
TOOL_R18_INTERNAL_WEBAPP_BASE_URL=http://127.0.0.1:8098

# This public URL is only used for links shown to the user.
TOOL_R18_PUBLIC_URL=http://43.167.237.120
REVERSE_TUNNEL_SSH_HOST=43.167.237.120
REVERSE_TUNNEL_SSH_USER=ubuntu
REVERSE_TUNNEL_SSH_KEY=C:\Users\WINDZLC\.ssh\tx_key.pem
REVERSE_TUNNEL_REMOTE_HOST=0.0.0.0
REVERSE_TUNNEL_REMOTE_PORT=19198
REVERSE_TUNNEL_LOCAL_HOST=127.0.0.1
REVERSE_TUNNEL_LOCAL_PORT=8098
REVERSE_TUNNEL_SSH_PASSWORD=

# Optional API keys can be kept here if you do not want to use api_config.json.
MINIMAX_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
